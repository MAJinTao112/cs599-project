# ============================================
# 智能旅行规划助手 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入真实的 API Key

# ============================================
# 模型 API 密钥（必填）
# ============================================

# DeepSeek API Key - 用于 DeepSeek R1 模型（复杂推理）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DashScope API Key - 用于 Qwen3 模型和文本嵌入
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ============================================
# LangChain 配置（可选，用于调试）
# ============================================

# LangChain 追踪开关（true/false）
LANGCHAIN_TRACING_V2=false

# LangChain API Key（如果启用追踪）
# LANGCHAIN_API_KEY=your-langchain-api-key-here

# ============================================
# MCP 配置路径（默认值，一般不需要修改）
# ============================================

# MCP 服务器配置文件路径
MCP_CONFIG_PATH=travel_agent/config/servers_config.json

# ============================================
# ChromaDB 向量数据库配置（默认值）
# ============================================

# 向量数据库存储路径
CHROMA_PERSIST_DIR=./data/travel_vectordb

# ============================================
# 使用说明
# ============================================
# 1. 复制此文件: cp .env.example .env
# 2. 填入真实的 API Key（替换 sk-your-xxx-key-here）
# 3. 保存文件后启动服务: langgraph dev
# 4. 注意: .env 文件已被 .gitignore 忽略，不会提交到 Git
